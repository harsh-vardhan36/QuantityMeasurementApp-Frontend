# ─────────────────────────────────────────────────────────────────────────────
# Quantity Measurement App - Environment Variables Template
# Copy this file to `.env` and fill in your real values.
# This file is safe to commit - it contains NO real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong key via: openssl rand -base64 64
APP_AUTH_TOKEN_SECRET=QuantityMeasurementAppSuperSecretKeyThatIsVeryLongAndSecure123!
APP_AUTH_TOKEN_EXPIRATION_MSEC=864000000

# ── Refresh Token ─────────────────────────────────────────────────────────────
# Duration in milliseconds — default 30 days (2592000000)
APP_AUTH_REFRESH_TOKEN_EXPIRATION_MSEC=2592000000

# ── OAuth2 ────────────────────────────────────────────────────────────────────
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID= 39818022572-gi13qv99vl59p3vca6f3bcrtjpgbionr.apps.googleusercontent.com

GOOGLE_CLIENT_SECRET=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
APP_OAUTH2_REDIRECT_URI=http://localhost:4200/oauth2/redirect

# ── Database ──────────────────────────────────────────────────────────────────
DB_USERNAME=quantity_measurement
DB_PASSWORD=root123
# Options: create | create-drop | update | validate | none
DB_INIT_MODE=update

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# For Gmail: enable 2-Step Verification then generate an App Password at:
# https://myaccount.google.com/apppasswords
# Do NOT use your regular Gmail password here.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=harsh15vardhan456@gmail.com
MAIL_PASSWORD=Root@123
